# Discord Bot Token — from discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Supabase Credentials — from your Supabase project settings
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_public_key_here

# Google Gemini API Key — from aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override health check port (default: 3000)
# PORT=3000

# NOTE: Once the bot starts, the invite link will be printed in the console.
# Share that link with anyone who wants to add the bot to their server.
